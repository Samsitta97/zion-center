spring:
  datasource:
    url: ${DB_URL:jdbc:mysql://localhost:3306/revealed_word_store}
    username: ${DB_USERNAME:root}
    password: ${DB_PASSWORD:your_local_db_password}
  jpa:
    hibernate:
      ddl-auto: none
    show-sql: true
  flyway:
    enabled: true
    locations: classpath:db/migration
    baseline-on-migrate: true
    baseline-version: 2
    repair-on-migrate: true

jwt:
  secret: ${JWT_SECRET:generate_a_64_char_hex_string_for_dev}
  expiration-ms: ${JWT_EXPIRATION_MS:900000}
  refresh-expiration-ms: ${JWT_REFRESH_EXPIRATION_MS:604800000}

server:
  port: ${SERVER_PORT:8080}

management:
  endpoints:
    web:
      exposure:
        include: health,info
  endpoint:
    health:
      show-details: always

app:
  base-url: ${APP_BASE_URL:http://localhost:8080}
  cors:
    allowed-origins: ${CORS_ALLOWED_ORIGINS:http://localhost:3000,http://localhost:5173}
  rate-limit:
    login-capacity: ${RATE_LIMIT_LOGIN_CAPACITY:20}
    login-refill-seconds: ${RATE_LIMIT_LOGIN_REFILL_SECONDS:60}

logging:
  level:
    com.zion.zion_center.security: DEBUG
    org.springframework.security: DEBUG
